local timeLockEnabled = false
local lockedTime      = 12
local timeLockConn    = nil

local function startTimeLock()
    if timeLockConn then timeLockConn:Disconnect() end
    Lighting.ClockTime = lockedTime
    timeLockConn = Lighting:GetPropertyChangedSignal("ClockTime"):Connect(function()
        if Lighting.ClockTime ~= lockedTime then
            Lighting.ClockTime = lockedTime
        end
    end)
    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for _, child in ipairs(terrain:GetChildren()) do
            if child:IsA("Clouds") then child.Enabled = false end
        end
    end
    local atm = Lighting:FindFirstChildOfClass("Atmosphere")
    if atm then
        atm.Name    = "Atmosphere1"
        atm.Density = 0.2
    end
end

local function stopTimeLock()
    if timeLockConn then
        timeLockConn:Disconnect()
        timeLockConn = nil
    end
end

