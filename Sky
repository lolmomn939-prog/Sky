-- Sky buttons
local selectedBtn = nil

local function cleanSkyOnly()
    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        for _, c in ipairs(terrain:GetChildren()) do
            if c:IsA("Clouds") then c:Destroy() end
        end
    end
    for _, obj in ipairs(Lighting:GetChildren()) do
        if obj:IsA("Sky") then obj:Destroy() end
    end
end

local function applySky(data, btn)
    cleanSkyOnly()
    local sky = Instance.new("Sky")
    sky.SkyboxBk, sky.SkyboxDn, sky.SkyboxFt = data.Bk, data.Dn, data.Ft
    sky.SkyboxLf, sky.SkyboxRt, sky.SkyboxUp = data.Lf, data.Rt, data.Up
    sky.SunTextureId, sky.SunAngularSize      = data.SunId, data.SunSize
    sky.MoonTextureId, sky.MoonAngularSize    = data.MoonId, data.MoonSize
    sky.StarCount = data.Stars
    sky.Parent    = Lighting

    if selectedBtn and selectedBtn ~= btn then
        TweenService:Create(selectedBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(28, 28, 28)}):Play()
        for _, c in ipairs(selectedBtn:GetChildren()) do
            if c:IsA("TextLabel") then
                c.TextColor3 = Color3.fromRGB(170, 170, 170)
            end
        end
    end
    TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(52, 52, 52)}):Play()
    for _, c in ipairs(btn:GetChildren()) do
        if c:IsA("TextLabel") then
            c.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end
    selectedBtn = btn
    -- UI يبقى مفتوح بعد الاختيار
end

