-- [ 3 ] الدوال المحدثة
local function cleanSkyOnly()
    -- حذف الغيوم من الـ Terrain مباشرة
    if Terrain then
        for _, cloud in ipairs(Terrain:GetChildren()) do
            if cloud:IsA("Clouds") then cloud:Destroy() end
        end
    end
    
    -- حذف الـ Skybox فقط من Lighting
    for _, obj in ipairs(Lighting:GetChildren()) do
        if obj:IsA("Sky") then obj:Destroy() end
    end
end

local function applySky(data)
    cleanSkyOnly() -- ينظف السماء والغيوم فقط
    
    local newSky = Instance.new("Sky")
    newSky.SkyboxBk, newSky.SkyboxDn, newSky.SkyboxFt = data.Bk, data.Dn, data.Ft
    newSky.SkyboxLf, newSky.SkyboxRt, newSky.SkyboxUp = data.Lf, data.Rt, data.Up
    newSky.SunTextureId, newSky.SunAngularSize = data.SunId, data.SunSize
    newSky.MoonTextureId, newSky.MoonAngularSize = data.MoonId, data.MoonSize
    newSky.StarCount = data.Stars
    newSky.Parent = Lighting
    ScreenGui.Enabled = false
end

